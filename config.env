# Shared configuration (committed). Used by local runs and GitHub Actions.
# Secrets live in .env (local) or GitHub Secrets (CI) — see .env.example.

DELIVERY_METHOD=whatsapp
SEND_FORMAT=auto
DRY_RUN=0

# gurbaninow | sgpc
HUKAMNAMA_SOURCE=sgpc
SGPC_URL=https://hs.sgpc.net/

# Send official SGPC hukamnama MP3 after the images (true | false)
SEND_AUDIO=true
# Also send katha MP3 — compressed automatically before upload
SEND_KATHA_AUDIO=true
# Target max size for compressed katha (MB)
KATHA_MAX_UPLOAD_MB=12

# Block re-sending the same day (sent-cache). Override in .env for local testing.
SKIP_SENT_CHECK=0

WHATSAPP_API_URL=https://api.green-api.com
WHATSAPP_MEDIA_URL=https://media.green-api.com
WHATSAPP_GROUPS_FILE=whatsapp_groups.json

INCLUDE_PUNJABI=true
INCLUDE_HINDI=true
INCLUDE_ENGLISH=true

SENT_CACHE_DIR=.sent-cache
FONTS_DIR=.fonts
IMAGE_OUTPUT_DIR=.generated-images
AUDIO_OUTPUT_DIR=.generated-audio