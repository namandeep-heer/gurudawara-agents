# Hukamnama daily trigger configuration (committed).
# Run .github/scripts/configure_hukamnama_trigger.ps1 after editing, then push.

# cron_job_org | github_schedule
HUKAMNAMA_TRIGGER=cron_job_org

# Daily send times in IST (24h HH:MM). Fallback only runs if primary did not send (sent-cache).
HUKAMNAMA_PRIMARY_IST=09:00
HUKAMNAMA_FALLBACK_IST=09:10