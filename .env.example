# Copy to .env and fill in secrets. Never commit .env.
#
# Service settings live in each service's config.env (hukamnama/config.env, scheduled_call/config.env).
# Daily trigger mode/times: hukamnama/trigger.env (apply with .github/scripts/configure_hukamnama_trigger.ps1).
# cron-job.org needs a GitHub PAT (Actions: Read and write) in its UI only — not here or in GitHub Secrets.
# Optional local overrides — uncomment to override config.env for testing:
# DRY_RUN=1
# SKIP_SENT_CHECK=1

# --- WhatsApp (Green API) — used by hukamnama and scheduled_call ---
WHATSAPP_ID_INSTANCE=
WHATSAPP_API_TOKEN=

# Optional: comma-separated group IDs (overrides hukamnama/whatsapp_groups.json)
WHATSAPP_GROUP_IDS=

# --- Email (if DELIVERY_METHOD=email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=

# --- ntfy (if DELIVERY_METHOD=ntfy) ---
NTFY_TOPIC=
NTFY_TOKEN=
NTFY_SERVER=https://ntfy.sh

