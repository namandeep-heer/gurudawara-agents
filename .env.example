# Copy to .env and fill in secrets. Never commit .env.
#
# All other settings are in config.env (one shared config for local + GitHub Actions).
# Optional local overrides — uncomment to override config.env for testing:
# DRY_RUN=1
# SKIP_SENT_CHECK=1

# --- WhatsApp (Green API) ---
WHATSAPP_ID_INSTANCE=
WHATSAPP_API_TOKEN=

# Optional: comma-separated group IDs (overrides whatsapp_groups.json)
WHATSAPP_GROUP_IDS=

# --- Email (if DELIVERY_METHOD=email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=

# --- ntfy (if DELIVERY_METHOD=ntfy) ---
NTFY_TOPIC=
NTFY_TOKEN=
NTFY_SERVER=https://ntfy.sh