# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.
#
# GitHub Actions setup (no UI needed):
#   1. Edit .github/repo-config.env  — non-secret CI settings (committed)
#   2. Edit whatsapp_groups.json     — target groups (committed)
#   3. Fill WHATSAPP_* below, then run:  .\scripts\setup_github.ps1
#      (requires: gh auth login — https://cli.github.com/)

# --- Delivery ---
# whatsapp | email | ntfy
DELIVERY_METHOD=whatsapp

# auto | image | text  (whatsapp defaults to image)
SEND_FORMAT=auto

# Set to 1 for a test run without sending
DRY_RUN=0

# --- WhatsApp (Green API) ---
# Get these from https://console.green-api.com/
WHATSAPP_ID_INSTANCE=
WHATSAPP_API_TOKEN=

# Optional: comma-separated group IDs (overrides whatsapp_groups.json)
WHATSAPP_GROUP_IDS=

WHATSAPP_API_URL=https://api.green-api.com
WHATSAPP_MEDIA_URL=https://media.green-api.com
WHATSAPP_GROUPS_FILE=whatsapp_groups.json

# --- Email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=

# --- ntfy ---
NTFY_TOPIC=
NTFY_TOKEN=
NTFY_SERVER=https://ntfy.sh

# --- Hukamnama content ---
INCLUDE_PUNJABI=true
INCLUDE_HINDI=true
INCLUDE_ENGLISH=true

# --- Paths ---
SENT_CACHE_DIR=.sent-cache
IMAGE_OUTPUT_DIR=.generated-images
FONTS_DIR=.fonts