# Scheduled reminder service (committed). Used by local runs and GitHub Actions.
# Delivers Punjabi WhatsApp voice notes via Green API (same secrets as hukamnama).
#
# Contacts must use WhatsApp on the numbers listed in contacts.json.
# Keep your linked phone (e.g. spare iPhone with Airtel SIM) online for Green API.
# Edit schedule.json any time to add, remove, move, or disable reminders.

DRY_RUN=0
SKIP_SENT_CHECK=0

WHATSAPP_API_URL=https://api.green-api.com
WHATSAPP_MEDIA_URL=https://media.green-api.com

CALL_TIMEZONE=Asia/Kolkata

SCHEDULE_FILE=schedule.json
CONTACTS_FILE=contacts.json
MESSAGE_FILE=message.txt

SENT_CACHE_DIR=.sent-cache
AUDIO_OUTPUT_DIR=.generated-audio

TTS_LANG=pa
SEND_TEXT_INTRO=false
MESSAGE_DELAY_SECONDS=30